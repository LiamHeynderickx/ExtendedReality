<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/space_background_gradient">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnInfoTop"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="46dp"
        app:icon="@drawable/ic_info"
        app:iconSize="32dp"
        app:iconTint="#5D89A1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/titleContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="8"
            android:text="FutureFoods"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.85"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.2"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="SEE THE EFFECTS OF CLIMATE CHANGE ON OUR FOODS"
            android:textAlignment="center"
            android:textColor="#E0F2F1"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Container for Orbiting Icons -->
    <FrameLayout
        android:id="@+id/orbitContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleContainer">

        <!-- Orbiting Icons will be added here programmatically -->

        <!-- Circular Rotating Button Container (Earth) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnStartCamera"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="130dp"
            app:cardElevation="12dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/rotatingEarth"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Rotating Earth"
                android:scaleType="centerCrop"
                android:src="@drawable/img" />

            <View
                android:id="@+id/clickOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Subtle instructional hint -->
        <TextView
            android:id="@+id/tapHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|bottom"
            android:layout_marginBottom="80dp"
            android:alpha="0"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="TAP THE EARTH TO START"
            android:textColor="@android:color/white"
            android:textSize="12sp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
