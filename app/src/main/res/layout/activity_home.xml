<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99C6DE">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnInfoTop"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        app:icon="@drawable/ic_info"
        app:iconTint="#5D89A1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/titleContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="FutureFoods"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="48sp" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.7"
            android:fontFamily="sans-serif-light"
            android:text="See the effects of climate change on our foods"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Circular Rotating Button Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnStartCamera"
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="150dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleContainer"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/rotatingEarth"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Rotating Earth"
            android:scaleType="centerCrop"
            android:src="@drawable/background2" />

        <View
            android:id="@+id/clickOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
